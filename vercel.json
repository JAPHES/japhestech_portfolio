{
  "version": 2,
  "buildCommand": "python -m pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "japhestech.settings"
  }
}
